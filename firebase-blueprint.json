{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Learning Commons app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "manager"] },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "TutoringRequest": {
      "title": "Tutoring Request",
      "description": "A request for a tutoring session",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "subject": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_teacher", "pending_manager", "approved", "rejected"] },
        "roomId": { "type": "string", "enum": ["room1", "room2", ""] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "studentName", "teacherId", "teacherName", "subject", "date", "startTime", "endTime", "status", "roomId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "requests/{requestId}": {
      "schema": { "$ref": "#/entities/TutoringRequest" },
      "description": "Tutoring requests"
    }
  }
}
